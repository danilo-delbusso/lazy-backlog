{
  "name": "lazy-backlog",
  "version": "0.2.0",
  "description": "AI-powered Jira ticket generation grounded in Confluence knowledge. Let AI do your backlog refinement.",
  "main": "dist/index.js",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ricky-Stevens/lazy-backlog.git"
  },
  "keywords": [
    "mcp",
    "jira",
    "confluence",
    "atlassian",
    "ai",
    "backlog",
    "tickets"
  ],
  "bin": {
    "lazy-backlog": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reportsDirectory=coverage",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "check": "npm run typecheck && npm run lint && vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "mdast-util-to-string": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  }
}
